{
  "name": "wefixit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 2552",
    "dev:https": "(local-ssl-proxy --source 2551 --target 2552) & next dev",
    "build": "next build",
    "build:check": "tsc --noEmit",
    "start": "next start --port 2551",
    "start:https": "(local-ssl-proxy --source 2551 --target 2552) & next start",
    "lint": "next lint",
    "prepare": "husky",
    "format:hard": "prettier --write .",
    "format": "pretty-quick --staged",
    "precommit:check": "pnpm lint && pnpm build:check"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@floating-ui/react": "^0.26.9",
    "@headlessui/react": "^1.7.18",
    "@hookform/resolvers": "^3.9.1",
    "@tanstack/react-query": "^4.32.6",
    "axios": "^1.6.8",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jotai": "^2.7.1",
    "lodash": "^4.17.21",
    "next": "14.2.18",
    "next-intl": "^3.15.3",
    "next-nprogress-bar": "^2.3.15",
    "pnpm": "^9.12.2",
    "react": "^18",
    "react-day-picker": "^8.10.0",
    "react-dom": "^18",
    "react-hook-form": "^7.53.2",
    "react-icons": "^5.3.0",
    "react-use": "^17.5.1",
    "sharp": "^0.33.5",
    "slick-carousel": "^1.8.1",
    "sonner": "^1.4.41",
    "swiper": "^10.0.0",
    "tailwind-merge": "^2.3.0",
    "use-file-picker": "^2.1.2",
    "zod": "^3.23.8",
    "zustand": "5.0.0-rc.2"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/lodash": "^4.17.7",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-slick": "^0.23.13",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "autoprefixer": "^10.0.1",
    "eslint": "8.56.0",
    "eslint-config-next": "14.1.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.2",
    "next-dev-https": "^0.13.3",
    "postcss": "^8",
    "prettier": "3.2.5",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "pretty-quick": "^4.0.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
